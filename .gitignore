### --- Docker & Docker Compose --- ###
# Environment files containing secrets
.env
.env.*
!.env.example

# Docker Compose data volumes (e.g., DB data persisted to host)
# Replace 'data/' with your specific volume mount path
data/
db_data/

# Temporary docker files
.docker_temp_*

